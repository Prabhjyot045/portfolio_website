<style>
/* ── Hero ─────────────────────────────────────────── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding-top: var(--nav-height);
}

.hero-grid-bg {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle at 1px 1px, rgba(88,166,255,0.06) 1px, transparent 0);
  background-size: 44px 44px;
  pointer-events: none;
}

.hero-glow {
  position: absolute;
  top: -10%;
  left: 50%;
  transform: translateX(-50%);
  width: 900px;
  height: 600px;
  background: radial-gradient(ellipse at center, rgba(88,166,255,0.1) 0%, transparent 65%);
  pointer-events: none;
}

.hero-inner {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 4rem;
  padding-top: 3rem;
  padding-bottom: 4rem;
}

.hero-content { max-width: 620px; }

.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--accent);
  background: var(--accent-dim);
  border: 1px solid rgba(88,166,255,0.25);
  border-radius: 50px;
  padding: 0.3rem 0.85rem;
  margin-bottom: 1.75rem;
}

.badge-dot {
  width: 6px;
  height: 6px;
  background: var(--green);
  border-radius: 50%;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.6; transform: scale(0.85); }
}

.hero-name {
  font-size: clamp(3rem, 7.5vw, 5.5rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  margin-bottom: 1.25rem;
  background: linear-gradient(130deg, #e6edf3 25%, #79b8ff 65%, #58a6ff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-tagline {
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 2.25rem;
  max-width: none;
}
.hero-tagline strong { color: var(--text); }

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  margin-bottom: 2.5rem;
}

.hero-social {
  display: flex;
  gap: 1.25rem;
}
.hero-social a {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.875rem;
  color: var(--text-muted);
  transition: color var(--transition);
}
.hero-social a:hover { color: var(--accent); }

.hero-graphic {
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.45;
}

.hex-grid {
  display: grid;
  grid-template-columns: repeat(3, 60px);
  gap: 8px;
  transform: rotate(15deg);
}

.hex {
  width: 60px;
  height: 60px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
}

.hex-1, .hex-5, .hex-9 { background: var(--accent-dim); border-color: rgba(88,166,255,0.3); }
.hex-3, .hex-7          { background: var(--green-dim);  border-color: rgba(63,185,80,0.3); }

.scroll-indicator {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  color: var(--text-dim);
  animation: bounce 2.2s infinite;
  transition: color var(--transition);
}
.scroll-indicator:hover { color: var(--accent); }

@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50%       { transform: translateX(-50%) translateY(7px); }
}

@media (max-width: 860px) {
  .hero-inner { grid-template-columns: 1fr; }
  .hero-graphic { display: none; }
}
@media (max-width: 480px) {
  .hero-actions { flex-direction: column; }
  .hero-actions .btn { justify-content: center; }
}

