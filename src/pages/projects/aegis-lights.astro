    text-align: center;
  }
  .asset-download {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    padding: 0.65rem 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--accent);
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color var(--transition), background var(--transition);
  }
