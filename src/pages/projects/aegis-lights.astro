        <source src="/assets/projects/aegis-lights/demo.mp4" type="video/mp4" />
        Your browser does not support the video element.
      </video>
      <p class="video-caption">Aegis Lights simulation — CityFlow traffic network responding to adaptive signal control in real time.</p>
    </div>
  )}

  {hasArchitectureDiagram && (
    <figure class="asset-figure">
      <img src="/assets/projects/aegis-lights/architecture.png" alt="Aegis Lights IBM Cloud deployment architecture" loading="lazy" />
      <figcaption>IBM Cloud deployment — K8s-orchestrated microservices: CityFlow Simulator, Virtual Sensors, MAPE-K FastAPI service, Signal Controllers, Knowledge Store, IBM COS, Log Analysis, and Sysdig monitoring.</figcaption>
    </figure>
  )}

  {hasDashboard && (
    <figure class="asset-figure">
      <img src="/assets/projects/aegis-lights/dashboard.png" alt="Aegis Lights live traffic network dashboard" loading="lazy" />
      <figcaption>Live Aegis Lights dashboard — real-time CityFlow network graph with colored intersection nodes, performance history charts, and energy metrics panel.</figcaption>
    </figure>
  )}

  {hasSimulator && (
    <figure class="asset-figure">
      <img src="/assets/projects/aegis-lights/simulator.png" alt="CityFlow simulator grid" loading="lazy" />
      <figcaption>CityFlow simulator grid — intersection network used for all low, medium, and high traffic density experiments.</figcaption>
    </figure>
  )}


